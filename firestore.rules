rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn()  { return request.auth != null; }
    function role()        { return request.auth.token.role; }
    function isAdmin()     { return isSignedIn() && role() == 'admin'; }
    function isCaptain()   { return isSignedIn() && role() == 'captain'; }

    // Team association is now stored in /teamMembers, not in the token claim.
    // This function checks whether the requesting user has a membership record
    // linking them to the given teamId for the current season.
    // NOTE: ACTIVE_SEASON is a client constant — rules use a hardcoded value
    // that must be updated when the season changes. Alternative: pass season
    // in the document and compare to a Firestore config document.
    function isMemberOf(teamId) {
      return isSignedIn() && exists(
        /databases/$(database)/documents/teamMembers/$(request.auth.uid + '_2026-summer')
      ) && get(
        /databases/$(database)/documents/teamMembers/$(request.auth.uid + '_2026-summer')
      ).data.teamId == teamId;
    }

    // ── /teams ────────────────────────────────────────────────────────────────
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // any signed-in user can register a team during open registration
      allow update: if isAdmin() || isMemberOf(teamId);
      allow delete: if isAdmin();
    }

    // ── /teams/{teamId}/roster ────────────────────────────────────────────────
    match /teams/{teamId}/roster/{playerId} {
      allow read:  if isAdmin() || isMemberOf(teamId);
      allow write: if isAdmin() || isMemberOf(teamId);
    }

    // ── /matches ─────────────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isCaptain() && (
          isMemberOf(resource.data.t1) || isMemberOf(resource.data.t2)
        ));
      allow delete: if isAdmin();
    }

    // ── /teamMembers ──────────────────────────────────────────────────────────
    match /teamMembers/{docId} {
      allow read:   if isAdmin() || (isSignedIn() && docId.matches(request.auth.uid + '_.*'));
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── /users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if isAdmin() || request.auth.uid == uid;
    }

    // ── /knockouts ────────────────────────────────────────────────────────────
    match /knockouts/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
